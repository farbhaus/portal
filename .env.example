# Portal configuration for the all-in-one image. Copy to .env and fill in. Run from this dir:
#   cp .env.example .env  &&  docker compose up -d
#
# The container bundles Postgres + Redis, so there are NO database/cache URLs to set — they're
# internal to the image. Crypto secrets are generated and persisted in the data volume on first
# boot, so the only values you MUST set are your domain and the admin login below.

# ── Required ─────────────────────────────────────────────────────────────────
# Public HTTPS URL clients reach Portal on. Everything else derives from this one value: WebAuthn
# passkeys, the Frame.io OAuth redirect, and — in standalone mode — the TLS cert's hostname.
BASE_URL=https://portal.example.com

# Single admin (v1), seeded on first startup. Portal refuses to start while ADMIN_PASSWORD is unset
# or the default — use a strong, unique password.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── TLS (how Portal is reached) ──────────────────────────────────────────────
# The one-click ./deploy.sh sets all of this for you. These knobs are only for driving compose by
# hand. Two modes:
#
#   • Standalone — Portal gets its OWN Let's Encrypt cert and owns ports 80/443. Uncomment:
#       # PORTAL_BEHIND_PROXY=false
#       # WEB_BIND=0.0.0.0
#       # PORTAL_PORT=80
#       # PORTAL_HTTPS_PORT=443
#
#   • Behind a reverse proxy you already run (default) — Portal binds 127.0.0.1:PORTAL_PORT and your
#     proxy terminates TLS and forwards your domain to it (see host-caddy.example). Nothing to set
#     beyond PORTAL_PORT; the proxy-hop count and HTTP-only listener are derived automatically.
PORTAL_PORT=18080
# Which published image tag to run (e.g. v1.0.0). 'latest' tracks the newest release.
PORTAL_VERSION=latest

# Advanced (rarely needed): SESSION_COOKIE_SECURE defaults true (the browser always reaches Portal
# over HTTPS); set false only for direct-HTTP loopback testing. TRUSTED_PROXY_HOPS is derived from
# the mode above (2 behind a proxy, 1 standalone) — override only for extra proxies (e.g. add
# Cloudflare in front of a host proxy → 3) so the rate limiter reads the real client IP.
# SESSION_COOKIE_SECURE=true
# TRUSTED_PROXY_HOPS=2

# ── Secrets (optional — auto-generated if unset) ─────────────────────────────
# On first boot these are generated and persisted under the data volume (/data/secrets), so you
# normally leave them blank. Set them explicitly only if you want to manage them yourself (e.g.
# from a secrets manager). TOKEN_ENCRYPTION_KEY encrypts stored Frame.io/SMTP credentials —
# whether generated or set, it must stay stable, which the data volume guarantees. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SESSION_SECRET=
# TOKEN_ENCRYPTION_KEY=

# ── Frame.io / Adobe IMS OAuth ───────────────────────────────────────────────
# Client ID & secret are managed in the Settings page (stored in the database, secret encrypted),
# NOT here. See the "Adobe Developer Console setup" section in the README. The redirect URI derives from BASE_URL
# (${BASE_URL}/api/frameio/oauth/callback); override only for non-standard setups. AdobeID is
# required for Frame.io API access (kept across token refreshes).
FRAMEIO_SCOPES=openid,AdobeID,email,profile,offline_access,additional_info.roles
FRAMEIO_REDIRECT_URI=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# SMTP host/port/credentials/from/notify address are managed in the Settings page (stored in the
# database, password encrypted), NOT here.

# ── Email verification (links with "Verify email" on) ────────────────────────
# A one-time code proves a client controls the address; a verified device is then trusted for
# VERIFY_TRUST_DAYS (sliding). VERIFY_CHECK_MX rejects domains with no mail servers before sending
# (set false if the container has no outbound DNS). Requires SMTP (configured in Settings).
VERIFY_CODE_TTL_SECONDS=600
VERIFY_MAX_ATTEMPTS=5
VERIFY_RESEND_COOLDOWN_SECONDS=30
VERIFY_TRUST_DAYS=30
VERIFY_CHECK_MX=true

# ── Tuning (optional) ────────────────────────────────────────────────────────
UVICORN_WORKERS=2
LOG_LEVEL=INFO
# Interactive OpenAPI docs at /api/docs. Off by default — the schema hands an attacker a map of
# the whole admin API; production has no use for it. Set true only for local development.
# EXPOSE_API_DOCS=false
# Reject Frame.io webhook deliveries whose timestamp is further than this from now (replay
# protection). Frame.io recommends ~5 minutes; only raise this if clocks drift.
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Sync engine: download attempts before a job is dead-lettered, the backoff base (the nth retry
# defers by SYNC_RETRY_BASE_SECONDS * 2**(n-1)), and parallel byte ranges per file download.
SYNC_MAX_RETRIES=5
SYNC_RETRY_BASE_SECONDS=30
SYNC_DOWNLOAD_CONCURRENCY=8
# Max sync downloads running at once (arq max_jobs). The bottleneck is the link to your sync
# destination: over a slow share (e.g. CIFS-on-VPN, ~18 MB/s) more parallel jobs just thrash it,
# so keep this low (default 3). On a fast local link the ceiling becomes your internet pull from
# Frame.io — raise to ~4-6 to keep the pipe full.
SYNC_MAX_CONCURRENT_JOBS=3
# How often (minutes) the reconcile cron sweeps watched folders for files added directly in
# Frame.io. Client uploads through Portal links sync immediately and don't wait for this. Each
# sweep lists the folder (rate-limited endpoint), so keep it modest (default 15).
SYNC_RECONCILE_INTERVAL_MINUTES=15
# A freshly uploaded large file isn't downloadable until Frame.io finalizes it. While not ready,
# the job re-checks every SYNC_SOURCE_POLL_SECONDS (without spending its retry budget) and gives up
# only after SYNC_SOURCE_READY_TIMEOUT_SECONDS. Raise the timeout for very large (100s of GB) files.
SYNC_SOURCE_POLL_SECONDS=120
SYNC_SOURCE_READY_TIMEOUT_SECONDS=21600

# Data retention (days): a daily worker cron deletes history rows older than these; 0 disables a
# given sweep. Sync jobs are never pruned (they're the copy-once ledger). AUDIT_LOG 0 = keep
# the audit trail indefinitely.
RETENTION_WEBHOOK_EVENTS_DAYS=90
RETENTION_SESSIONS_DAYS=365
RETENTION_AUDIT_LOG_DAYS=0

# Host directory bind-mounted into the container (rslave) where sync rules write files. Point a
# sync rule's destination path under here; any filesystem you mount under this root on the host
# (e.g. an fstab NAS mount) shows up automatically. It must exist on the host — deploy.sh creates
# it, and the default /mnt exists on Linux (on macOS/dev, set this to a path you can create, e.g.
# ./portal-sync). Remove the bind in docker-compose.yml if you don't use sync rules.
SYNC_HOST_ROOT=/mnt
