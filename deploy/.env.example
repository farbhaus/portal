# Portal configuration. Copy to .env and fill in. Run compose from this directory:
#   cp .env.example .env  &&  docker compose up -d

# ── Ingress ──────────────────────────────────────────────────────────────────
# Portal's internal Caddy binds 127.0.0.1:PORTAL_PORT. Your host reverse proxy
# (Caddy/nginx/Traefik) forwards your domain to this port. See host-caddy.example.
PORTAL_PORT=18080
BASE_URL=http://127.0.0.1:18080
# Number of trusted proxies in front of the API; the rate limiter reads the real client IP as the
# Nth X-Forwarded-For entry from the right so it can't be spoofed. Default 2 = host proxy + Portal's
# internal Caddy. Add 1 per extra proxy (e.g. Cloudflare → 3); set 0 if nothing fronts the API.
TRUSTED_PROXY_HOPS=2

# ── Database (Postgres) ──────────────────────────────────────────────────────
POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=portal
# Must match the three values above. Host is the compose service name.
DATABASE_URL=postgresql+asyncpg://portal:change-me-postgres-password@portal_postgres:5432/portal

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://portal_redis:6379/0

# ── Secrets ──────────────────────────────────────────────────────────────────
# REQUIRED — the API refuses to start while any of SESSION_SECRET / TOKEN_ENCRYPTION_KEY /
# ADMIN_PASSWORD is left at its placeholder (set ALLOW_INSECURE_DEFAULTS=true only for a
# throwaway local run). Generate each with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-session-secret
TOKEN_ENCRYPTION_KEY=change-me-token-encryption-key

# ── Admin (single admin in v1; seeded on first startup) ──────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# ── Frame.io / Adobe IMS OAuth ───────────────────────────────────────────────
# Client ID & secret are now managed in the Settings page (stored in the database,
# secret encrypted), NOT here — leave these blank. On first startup any values still
# present here are imported once into the database, then ignored. See
# deploy/ADOBE_DEVELOPER_CONSOLE_SETUP.md. The redirect URI is derived from BASE_URL
# (${BASE_URL}/api/frameio/oauth/callback); override only for non-standard setups.
# AdobeID is required for Frame.io API access (kept across token refreshes).
FRAMEIO_SCOPES=openid,AdobeID,email,profile,offline_access,additional_info.roles
FRAMEIO_REDIRECT_URI=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# SMTP host/port/credentials/from/notify address are now managed in the Settings
# page (stored in the database, password encrypted), NOT here. On first startup any
# values still present here are imported once into the database, then ignored.

# ── Email verification (links with "Verify email" on) ────────────────────────
# A one-time code proves a client controls the address; a verified device is then trusted for
# VERIFY_TRUST_DAYS (sliding). VERIFY_CHECK_MX rejects domains with no mail servers before sending
# (set false if the worker has no outbound DNS). Requires SMTP above to be configured.
VERIFY_CODE_TTL_SECONDS=600
VERIFY_MAX_ATTEMPTS=5
VERIFY_RESEND_COOLDOWN_SECONDS=30
VERIFY_TRUST_DAYS=30
VERIFY_CHECK_MX=true

# ── Session cookie ───────────────────────────────────────────────────────────
# Set to true in production (browser reaches Portal over HTTPS via the host proxy).
# Set to false only for direct HTTP access to the loopback port during local testing.
SESSION_COOKIE_SECURE=false

# ── Tuning (optional) ────────────────────────────────────────────────────────
UVICORN_WORKERS=2
LOG_LEVEL=INFO
# Reject Frame.io webhook deliveries whose timestamp is further than this from now (replay
# protection). Frame.io recommends ~5 minutes; only raise this if clocks drift.
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Sync engine: download attempts before a job is dead-lettered, the backoff base (the nth retry
# defers by SYNC_RETRY_BASE_SECONDS * 2**(n-1)), and parallel byte ranges per file download.
SYNC_MAX_RETRIES=5
SYNC_RETRY_BASE_SECONDS=30
SYNC_DOWNLOAD_CONCURRENCY=8
# Max sync downloads running at once (arq max_jobs). The bottleneck is the link to your sync
# destination: over a slow share (e.g. CIFS-on-VPN, ~18 MB/s) more parallel jobs just thrash it,
# so keep this low (default 3). On a fast local link (e.g. a NAS VM with 10 Gb to the share) the
# ceiling becomes your internet pull from Frame.io — raise to ~4-6 to keep the pipe full.
SYNC_MAX_CONCURRENT_JOBS=3
# How often (minutes) the reconcile cron sweeps watched folders for files added directly in
# Frame.io. Client uploads through Portal links sync immediately on completion and don't wait for
# this. Each sweep lists the folder (rate-limited endpoint), so keep it modest (default 15).
SYNC_RECONCILE_INTERVAL_MINUTES=15
# A freshly uploaded large file isn't downloadable until Frame.io finalizes it. While not ready,
# the job re-checks every SYNC_SOURCE_POLL_SECONDS (without spending its retry budget) and gives up
# only after SYNC_SOURCE_READY_TIMEOUT_SECONDS. Raise the timeout for very large (100s of GB) files.
SYNC_SOURCE_POLL_SECONDS=120
SYNC_SOURCE_READY_TIMEOUT_SECONDS=21600

# Data retention (days): a daily worker cron deletes history rows older than these; 0 disables a
# given sweep. Sync jobs are never pruned (they're the copy-once ledger — deleting them would
# re-download already-synced files). AUDIT_LOG defaults to 0 = keep the audit trail indefinitely.
RETENTION_WEBHOOK_EVENTS_DAYS=90
RETENTION_SESSIONS_DAYS=365
RETENTION_AUDIT_LOG_DAYS=0

# Host directory bind-mounted into the worker (with rslave propagation) where sync rules write
# files. Set a sync rule's destination path to something under here. Any filesystem you mount
# under this root on the host (e.g. an fstab NAS mount) shows up in the worker automatically.
SYNC_HOST_ROOT=/mnt
