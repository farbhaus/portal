# Portal configuration. Copy to .env and fill in. Run compose from this directory:
#   cp .env.example .env  &&  docker compose up -d

# ── Ingress ──────────────────────────────────────────────────────────────────
# Portal's internal Caddy binds 127.0.0.1:PORTAL_PORT. Your host reverse proxy
# (Caddy/nginx/Traefik) forwards your domain to this port. See host-caddy.example.
PORTAL_PORT=18080
BASE_URL=http://127.0.0.1:18080

# ── Database (Postgres) ──────────────────────────────────────────────────────
POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=portal
# Must match the three values above. Host is the compose service name.
DATABASE_URL=postgresql+asyncpg://portal:change-me-postgres-password@portal_postgres:5432/portal

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://portal_redis:6379/0

# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate each with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-session-secret
TOKEN_ENCRYPTION_KEY=change-me-token-encryption-key

# ── Admin (single admin in v1; seeded on first startup) ──────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# ── Frame.io / Adobe IMS OAuth ───────────────────────────────────────────────
# From your Adobe Developer Console "Web App" integration. See
# deploy/ADOBE_DEVELOPER_CONSOLE_SETUP.md. The redirect URI registered there must match
# FRAMEIO_REDIRECT_URI (defaults to ${BASE_URL}/api/frameio/oauth/callback when blank).
FRAMEIO_CLIENT_ID=
FRAMEIO_CLIENT_SECRET=
# AdobeID is required for Frame.io API access (kept across token refreshes).
FRAMEIO_SCOPES=openid,AdobeID,email,profile,offline_access,additional_info.roles
FRAMEIO_REDIRECT_URI=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for upload-completion and download notifications. Leave SMTP_HOST blank to
# disable email entirely. Port 587 = STARTTLS (SMTP_STARTTLS=true); 465 = implicit
# TLS (SMTP_USE_TLS=true). Notifications go to NOTIFY_EMAIL, or ADMIN_EMAIL if blank.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=false
SMTP_STARTTLS=true
NOTIFY_EMAIL=

# ── Session cookie ───────────────────────────────────────────────────────────
# Set to true in production (browser reaches Portal over HTTPS via the host proxy).
# Set to false only for direct HTTP access to the loopback port during local testing.
SESSION_COOKIE_SECURE=false

# ── Tuning (optional) ────────────────────────────────────────────────────────
UVICORN_WORKERS=2
LOG_LEVEL=INFO
# Reject Frame.io webhook deliveries whose timestamp is further than this from now (replay
# protection). Frame.io recommends ~5 minutes; only raise this if clocks drift.
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Sync engine: download attempts before a job is dead-lettered, the backoff base (the nth retry
# defers by SYNC_RETRY_BASE_SECONDS * 2**(n-1)), and parallel byte ranges per file download.
SYNC_MAX_RETRIES=5
SYNC_RETRY_BASE_SECONDS=30
SYNC_DOWNLOAD_CONCURRENCY=4
