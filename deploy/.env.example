# Portal configuration. Copy to .env and fill in. Run compose from this directory:
#   cp .env.example .env  &&  docker compose up -d

# ── Ingress ──────────────────────────────────────────────────────────────────
# Portal's internal Caddy binds 127.0.0.1:PORTAL_PORT. Your host reverse proxy
# (Caddy/nginx/Traefik) forwards your domain to this port. See host-caddy.example.
PORTAL_PORT=18080
BASE_URL=http://127.0.0.1:18080

# ── Database (Postgres) ──────────────────────────────────────────────────────
POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=portal
# Must match the three values above. Host is the compose service name.
DATABASE_URL=postgresql+asyncpg://portal:change-me-postgres-password@portal_postgres:5432/portal

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://portal_redis:6379/0

# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate each with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-session-secret
TOKEN_ENCRYPTION_KEY=change-me-token-encryption-key

# ── Admin (single admin in v1; seeded on first startup) ──────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# ── Session cookie ───────────────────────────────────────────────────────────
# Set to true in production (browser reaches Portal over HTTPS via the host proxy).
# Set to false only for direct HTTP access to the loopback port during local testing.
SESSION_COOKIE_SECURE=false

# ── Tuning (optional) ────────────────────────────────────────────────────────
UVICORN_WORKERS=2
LOG_LEVEL=INFO
