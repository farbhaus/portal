    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.9.2",
    "openapi-typescript": "^7.6.1",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
