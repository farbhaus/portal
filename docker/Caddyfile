# Portal's internal Caddy. HTTP only — TLS is terminated by the host's reverse proxy,
# which forwards a single domain to 127.0.0.1:${PORTAL_PORT}. This Caddy only does
# internal routing between the API and the SvelteKit frontend.
:80 {
	# Security headers on every response (HTML pages come from the SvelteKit server, not the
	# API, so setting these here is the one place that covers both). `Set` semantics replace any
	# value the upstream sent, so there's no duplication. HSTS is intentionally left to the host
	# proxy that terminates TLS. CSP here is limited to frame-ancestors (clickjacking + the admin
	# QR @html sink) so it can't break SvelteKit's inline hydration; a full script-src CSP would
	# need SvelteKit's own csp config and is a separate change.
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "frame-ancestors 'none'"
		-Server
	}

	handle /api/* {
		reverse_proxy portal_api:8000
	}
	handle {
		reverse_proxy portal_web:3000
	}
}
